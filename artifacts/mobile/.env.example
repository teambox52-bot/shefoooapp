# HealthSync Laravel backend API URL for Expo client code.
# Expo reads EXPO_PUBLIC_* variables in the app bundle.
# VITE_API_BASE_URL is kept only for backward compatibility with older local config.

EXPO_PUBLIC_API_BASE_URL=https://nest-dean-virginia-acrobat.trycloudflare.com/api
VITE_API_BASE_URL=https://nest-dean-virginia-acrobat.trycloudflare.com/api

# For a physical phone on LAN without Cloudflare, use:
# EXPO_PUBLIC_API_BASE_URL=http://<BACKEND_PC_IP>:8000/api
# VITE_API_BASE_URL=http://<BACKEND_PC_IP>:8000/api

# After changing this file, restart Metro with:
# pnpm exec expo start --lan --clear
